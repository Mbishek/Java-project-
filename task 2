package task2_inheritance;

public class Employee {
    double salary;

    // Constructor
    public Employee(double salary) {
        this.salary = salary;
    }

    // Method to calculate salary
    double calculateSalary() {
        return salary;
    }
}
package task2_inheritance;

public interface Bonus {
    double calculateBonus();
}
package task2_inheritance;

public class Manager extends Employee implements Bonus {

    // Constructor
    public Manager(double salary) {
        super(salary);
    }

    // Implement bonus calculation
    public double calculateBonus() {
        return salary * 0.10;
    }
}
package task2_inheritance;

public class Main {
    public static void main(String[] args) {
        Manager m = new Manager(30000);

        System.out.println("Salary: " + m.calculateSalary());
        System.out.println("Bonus: " + m.calculateBonus());
    }
}
