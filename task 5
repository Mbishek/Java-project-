package task5_threading;

public class SalaryThread extends Thread {

    @Override
    public void run() {
        System.out.println("Running thread: " + Thread.currentThread().getName());
    }
}
package task5_threading;

public class PayrollThread {

    public static void main(String[] args) {

        // Create thread objects
        SalaryThread t1 = new SalaryThread();
        SalaryThread t2 = new SalaryThread();

        // Start threads
        t1.start();
        t2.start();
    }
}
